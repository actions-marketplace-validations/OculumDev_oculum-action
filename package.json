{
  "name": "@oculum/github-action",
  "version": "1.0.2",
  "description": "Oculum Security Scanner GitHub Action",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "build:watch": "npm run build -- --watch",
    "deploy": "./scripts/deploy-to-public.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@oculum/scanner": "*",
    "@oculum/shared": "*",
    "minimatch": "^10.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5"
  }
}
