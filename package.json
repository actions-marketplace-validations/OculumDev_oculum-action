{
  "name": "@oculum/github-action",
  "version": "1.0.3",
  "description": "Oculum Security Scanner GitHub Action - AI-native security for LLM-powered applications",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/oculum-security/oculum-action.git"
  },
  "homepage": "https://oculum.dev",
  "bugs": {
    "url": "https://github.com/oculum-security/oculum-action/issues"
  },
  "keywords": [
    "github-action",
    "security",
    "scanner",
    "sast",
    "ai-security",
    "llm",
    "prompt-injection",
    "vulnerability"
  ],
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "build:watch": "npm run build -- --watch",
    "deploy": "./scripts/deploy-to-public.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@oculum/scanner": "^1.0.11",
    "@oculum/shared": "^1.0.6",
    "minimatch": "^10.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5"
  }
}
